    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  }
}
